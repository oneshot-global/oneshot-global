# ============================================================
# OneShotCal — 環境変数テンプレート
# このファイルをコピーして .env を作成し、値を埋めてください。
# .env は Git にコミットしないこと (.gitignore に追加済みであることを確認)
# Cloud Run にデプロイする場合は、同じ変数を Cloud Run の環境変数に設定してください。
# ============================================================

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://oneshotcal.com/auth/google/callback

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── CORS ─────────────────────────────────────────────────────
# 許可するオリジンをカンマ区切りで指定。必須。
# 未設定の場合はサーバーが起動しません。
# 本番:   ALLOWED_ORIGINS=https://oneshotcal.com
# 開発時: ALLOWED_ORIGINS=https://oneshotcal.com,http://localhost:3000
ALLOWED_ORIGINS=https://oneshotcal.com

# ── セッション署名キー ────────────────────────────────────────
# 必須。未設定の場合はサーバーが起動しません。
# 生成方法: openssl rand -base64 32
# ローテーション方法: 旧キーを SESSION_KEY_OLD に残し、
#   worker.js の keys: [SESSION_KEY, SESSION_KEY_OLD] にすると
#   既存ユーザーのセッションを壊さずに移行できます。
SESSION_KEY=

# ── サーバー ─────────────────────────────────────────────────
# Cloud Run では自動設定されるため通常は不要
# PORT=8080
